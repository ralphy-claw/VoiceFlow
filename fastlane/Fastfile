default_platform(:ios)

platform :ios do

  desc "Build and upload to TestFlight"
  desc "Usage: fastlane beta"
  desc "Options:"
  desc "  notes:'Your release notes' - Custom release notes for testers"
  desc "  skip_notes:true - Skip release notes prompt"
  lane :beta do |options|
    build_number = (sh("git rev-list --count HEAD", log: false).strip.to_i + 100).to_s

    # Setup ASC API key
    key_id = ENV["ASC_KEY_VOICEFLOW_ID"] || "CPWGH6B5H6"
    key_issuer = ENV["ASC_KEY_VOICEFLOW_ISSUER_ID"] || "e576b7d5-3c0e-4d7d-ae33-294c6639571a"
    key_path = ENV["ASC_KEY_VOICEFLOW_FILEPATH"] || "/Users/ralphy-claw/.openclaw/workspace/projects/Pixella/fastlane/AuthKey_PIXELLA.p8"

    api_key = app_store_connect_api_key(
      key_id: key_id,
      issuer_id: key_issuer,
      key_filepath: key_path,
      duration: 1200,
      in_house: false
    )

    UI.header("Building VoiceFlow for TestFlight")

    # Update build number in xcconfig
    xcconfig_path = File.join(Dir.pwd, "..", "Configurations", "Base", "Base.xcconfig")
    if File.exist?(xcconfig_path)
      content = File.read(xcconfig_path)
      content.gsub!(/CURRENT_PROJECT_VERSION\s*=\s*\d+/, "CURRENT_PROJECT_VERSION = #{build_number}")
      File.write(xcconfig_path, content)
    end

    UI.success("Build #{build_number}")

    # Build — ASC API key xcargs handles signing automatically (no match needed)
    gym(
      scheme: "VoiceFlow",
      configuration: "Release",
      export_method: "app-store",
      output_directory: "./build",
      output_name: "VoiceFlow.ipa",
      clean: true,
      xcargs: "-allowProvisioningUpdates -authenticationKeyPath '#{key_path}' -authenticationKeyID #{key_id} -authenticationKeyIssuerID #{key_issuer} CURRENT_PROJECT_VERSION=#{build_number}"
    )

    # Upload to TestFlight
    pilot(
      api_key: api_key,
      app_identifier: "com.lubodev.voiceflow",
      team_id: "79NK8S894T",
      skip_waiting_for_build_processing: true,
      distribute_external: false
    )

    # Bump commit and push
    marketing_version = get_version_number(xcodeproj: "VoiceFlow.xcodeproj", target: "VoiceFlow")
    sh("git add -A")
    sh("git commit -m 'Version Bump: v#{marketing_version}(#{build_number})' --allow-empty")
    sh("git push origin HEAD")

    UI.success("✅ VoiceFlow build #{build_number} uploaded to TestFlight!")
  end

  desc "Build without uploading (validation)"
  desc "Usage: fastlane build"
  lane :build do
    gym(
      scheme: "VoiceFlow",
      configuration: "Release",
      skip_archive: true,
      skip_codesigning: true,
      destination: "generic/platform=iOS Simulator"
    )
    UI.success("Build succeeded!")
  end

  desc "Run unit tests"
  lane :tests do
    scan(
      scheme: "VoiceFlow",
      device: "iPhone 16 Pro",
      clean: true
    )
  end

end
